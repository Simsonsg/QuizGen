# Comma-separated provider fallback chain — tried left to right on rate limit
# Options: groq, gemini, anthropic
LLM_PROVIDERS=groq,gemini

# Optional: override the model per provider
# LLM_MODEL_GROQ=llama-3.3-70b-versatile
# LLM_MODEL_GEMINI=gemini-2.0-flash
# LLM_MODEL_ANTHROPIC=claude-haiku-4-5-20251001

# API keys — only providers listed in LLM_PROVIDERS need a key
GROQ_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here
